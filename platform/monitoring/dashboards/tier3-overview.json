{
  "title": "Tier3 - Application Overview",
  "uid": "tier3-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["tier3"],
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (route)", "legendFormat": "{{route}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ]
    },
    {
      "type": "stat",
      "title": "Backend Pods Ready",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "kube_deployment_status_replicas_available{deployment=\"backend\"}" }
      ]
    }
  ]
}
